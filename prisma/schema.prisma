// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id            String    @id @default(cuid())
  jobType       JobType
  status        JobStatus @default(PENDING)
  inputKeys     String[]
  outputKey     String?
  splitRanges   String?
  errorMessage  String?
  correlationId String    @unique
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum JobType {
  MERGE
  SPLIT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
