{
  "name": "@ilovepdf/worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=../../.env ../../node_modules/.bin/tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@ilovepdf/shared": "*",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.79.2",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "sharp": "^0.33.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
