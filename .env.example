# ============================================================
# Environment Variable Reference
# Copy this file to .env and fill in values for local dev.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ilovepdf

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible object storage
# For local dev, MinIO runs in Docker on port 9000.
# For production, replace with AWS S3 credentials.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ilovepdf
MINIO_USE_SSL=false

# File processing limits
MAX_FILE_SIZE_BYTES=52428800      # 50 MB per file
MAX_TOTAL_SIZE_BYTES=209715200    # 200 MB total across all files

# File retention (seconds). Input and output files are deleted after this TTL.
# Cleanup enforcement is a future feature; this value is stored in Job.expiresAt.
FILE_TTL_SECONDS=3600             # 1 hour

# Worker configuration
WORKER_CONCURRENCY=2              # Concurrent merge jobs per worker process

# Download URL TTL (seconds). Pre-signed MinIO/S3 URLs expire after this.
DOWNLOAD_URL_TTL_SECONDS=300      # 5 minutes

# Next.js
NEXT_TELEMETRY_DISABLED=1
